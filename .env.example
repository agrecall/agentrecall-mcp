# AgentRecall Environment Configuration
# 复制此文件为 .env 并填写实际值

# ============================================
# 数据库配置
# ============================================
DB_PASSWORD=your_secure_database_password_here

# ============================================
# JWT 配置
# ============================================
# JWT 密钥（至少 32 字节随机字符串，用于签名 JWT）
JWT_SECRET=your_jwt_secret_key_min_32_chars_long

# JWT 过期时间（默认 30 天）
JWT_EXPIRES_IN=30d

# ============================================
# OTP 配置
# ============================================
# OTP 主密钥（用于生成和验证 OTP，至少 32 字节）
OTP_MASTER_KEY=your_otp_master_key_min_32_chars_long

# ============================================
# 可选：外部服务配置
# ============================================
# OpenAI API Key（用于生成向量嵌入，可选）
# OPENAI_API_KEY=sk-xxx

# 向量模型选择（openai 或 local）
# EMBEDDING_PROVIDER=openai

# ============================================
# 可选：监控配置
# ============================================
# Sentry DSN（错误监控，可选）
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ============================================
# 可选：日志配置
# ============================================
# 日志级别（debug, info, warn, error）
LOG_LEVEL=info

# 日志格式（json 或 text）
LOG_FORMAT=json
